# ── Base de datos ──────────────────────────────────────────────
# El backend corre nativo; PostgreSQL está en Docker expuesto en localhost:5432
DATABASE_URL=postgresql+asyncpg://audit:CAMBIA_ESTA_CONTRASEÑA@localhost:5432/medical_audit

# ── Seguridad ──────────────────────────────────────────────────
# Genera con: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SECRET_KEY=CAMBIA_ESTO_32_BYTES_BASE64

# ── PostgreSQL (usado por el servicio "db" en docker-compose) ──
POSTGRES_USER=audit
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_DB=medical_audit

# ── Ruta de datos de auditoría ─────────────────────────────────
# Dev (Windows, backend nativo): ruta absoluta a la carpeta compartida
# Prod (Docker): no se necesita en .env — el compose define AUDIT_DATA_ROOT=/audit_data
AUDIT_DATA_ROOT=C:\Users\TU_USUARIO\Desktop\Carpeta compartida

# ── Opcionales ─────────────────────────────────────────────────
LOG_LEVEL=INFO
DOCS_ENABLED=false   # Nunca true en producción
