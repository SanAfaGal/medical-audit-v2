# ── Base de datos ──────────────────────────────────────────────
# En Docker Compose el host DEBE ser "db" (nombre del servicio)
DATABASE_URL=postgresql+asyncpg://audit:CAMBIA_ESTA_CONTRASEÑA@db:5432/medical_audit

# ── Seguridad ──────────────────────────────────────────────────
# Genera con: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SECRET_KEY=CAMBIA_ESTO_32_BYTES_BASE64

# ── PostgreSQL (usado por el servicio "db" en docker-compose) ──
POSTGRES_USER=audit
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_DB=medical_audit

# ── Ruta de auditoría (bind mount hacia el contenedor) ─────────
# Carpeta del HOST donde viven las subcarpetas de auditoría.
# Por defecto: carpeta "audit_data/" dentro del proyecto.
# Para usar otra ubicación cambia este valor (barras /) y reinicia:
#   docker compose up -d backend
AUDIT_HOST_PATH=./audit_data

# ── Opcionales ─────────────────────────────────────────────────
LOG_LEVEL=INFO
DOCS_ENABLED=false   # Nunca true en producción
